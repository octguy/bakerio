# Root .env.example
# Purpose: GitHub Actions repository secrets template.
# Local real file: .env (ignored)
# GitHub UI: Settings → Secrets and variables → Actions → Repository secrets

DOCKER_USERNAME=<dockerhub-username-or-org>
DOCKER_PASSWORD=<dockerhub-access-token-not-account-password>

VPS_HOST=<public-vps-host-or-ip>
VPS_USER=deploy
VPS_SSH_KEY=<private-deploy-key-contents>
VPS_PORT=22

FTP_HOST=<ftp-host>
FTP_USERNAME=<ftp-username>
FTP_PASSWORD=<ftp-password>
FTP_REMOTE_DIR=/

API_URL=https://api.example.com
BRANDING_URL=https://example.com
ORDER_URL=https://order.example.com
ADMIN_URL=https://admin.example.com
CONTACT_ENDPOINT=
