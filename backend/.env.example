# backend/.env.example
# Purpose: local backend development only.
# Local real file: backend/.env (ignored)

# Server
SERVER_ENV=development
SERVER_PORT=8080
GIN_MODE=debug

# JWT
JWT_SECRET=change-me-to-a-long-random-dev-secret
JWT_EXPIRY=15m

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=bakerio
DB_PASSWORD=change-me
DB_NAME=bakeriodb
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email (MailHog for local dev)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@bakerio.local

# Object storage (local MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
