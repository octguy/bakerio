# Server
SERVER_ENV=development
SERVER_PORT=8080
GIN_MODE=debug

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=15m

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=secret
DB_PASSWORD=secret
DB_NAME=database
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email (MailHog for local dev)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@bakerio.com

# Object storage (MinIO, S3-compatible) — product images
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bakerio
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
