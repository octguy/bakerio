# backend/deployments/.env.prod.example
# Purpose: production Docker Compose runtime env.
# VPS real file: /home/deploy/bakerio/backend/deployments/.env.prod (ignored)

# Docker images
DOCKER_USERNAME=<dockerhub-username-or-org>
IMAGE_TAG=latest

# Server
SERVER_PORT=8080
JWT_SECRET=<64-char-random-secret>
JWT_EXPIRY=15m

# Postgres
DB_USER=bakerio
DB_PASSWORD=<strong-db-password>
DB_NAME=bakeriodb

# Redis
REDIS_PASSWORD=<strong-redis-password>

# RabbitMQ
RABBITMQ_USER=bakerio
RABBITMQ_PASSWORD=<strong-rabbitmq-password>

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=bakerio
MINIO_ROOT_PASSWORD=<strong-minio-password-min-8-chars>
MINIO_BUCKET=uploads

# Email (cPanel mail server)
EMAIL_HOST=mail.thinhuit.id.vn
EMAIL_PORT=465
EMAIL_USER=admin@thinhuit.id.vn
EMAIL_PASSWORD=<mail-password>
EMAIL_FROM=admin@thinhuit.id.vn

# Public URLs
API_URL=https://api.bakerio.thinhuit.id.vn
BRANDING_URL=https://thinhuit.id.vn
ORDER_URL=https://order.bakerio.thinhuit.id.vn
ADMIN_URL=https://admin.bakerio.thinhuit.id.vn
CONTACT_ENDPOINT=
