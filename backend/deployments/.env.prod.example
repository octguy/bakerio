# Docker
DOCKER_USERNAME=yourdockerhub

# Server
SERVER_PORT=8080
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=15m

# Postgres
DB_USER=bakerio
DB_PASSWORD=change-me
DB_NAME=bakeriodb

# Redis
REDIS_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USER=bakerio
RABBITMQ_PASSWORD=change-me

# Email (your cPanel mail server)
EMAIL_HOST=mail.bakerio.vn
EMAIL_PORT=465
EMAIL_USER=noreply@bakerio.vn
EMAIL_PASSWORD=change-me
EMAIL_FROM=noreply@bakerio.vn

# Frontend
API_URL=https://api.bakerio.vn
