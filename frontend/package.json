{
  "name": "frontend",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:deployed": "playwright test --config=playwright.deployed.config.ts",
    "test:deployed:ui": "playwright test --ui --config=playwright.deployed.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "capture": "node scripts/capture.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
